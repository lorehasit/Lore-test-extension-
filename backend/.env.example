# Copy this file to `.env` and fill in what you have.
#
# Leave GROQ_API_KEY blank to run in MOCK mode — the backend works with zero
# keys, answering /why over a curated seed corpus. Fill it in to go LIVE:
# real mem0 memory, real Groq answers, real GitHub PR ingestion.

# --- LLM (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Embeddings (local, free, no key) ---
# Runs on your machine via fastembed. Downloads once on first live run.
# EMBEDDER_DIMS must match the model: gte-large=1024, bge-small-en-v1.5=384, bge-base=768.
EMBEDDER_MODEL=thenlper/gte-large
EMBEDDER_DIMS=1024

# --- Canon storage (vector memory) ---
# "qdrant"  = local file, offline dev (default)
# "pgvector" = hosted Postgres — the shared team brain. Requires DATABASE_URL
#              and `pip install -r requirements-pgvector.txt`.
VECTOR_STORE=qdrant
# Supabase/Neon connection string, e.g. postgresql://user:pass@host:5432/db?sslmode=require
DATABASE_URL=

# --- Optional: live GitHub PR ingestion (personal token) ---
# A classic or fine-grained token with read access to the repos you ingest.
GITHUB_TOKEN=

# --- GitHub App webhook (auto-capture merged PRs) ---
# The secret you set when creating the GitHub App; verifies webhook authenticity.
GITHUB_WEBHOOK_SECRET=

# --- GitHub App identity (multi-repo backfill + welcome comments) ---
# With these set, installing the App triggers a backfill of the last
# BACKFILL_DAYS of PRs across ALL selected repos (titles, bodies, review
# threads) and posts a one-time welcome comment on each open PR.
# App ID: shown on the GitHub App's settings page.
GITHUB_APP_ID=
# Private key: EITHER paste the whole .pem here (base64-encode it to survive
# newline-stripping dashboards) ...
GITHUB_APP_PRIVATE_KEY=
# ... OR point to the downloaded .pem file on disk.
GITHUB_APP_PRIVATE_KEY_PATH=
# How many days back the install-time backfill reaches.
BACKFILL_DAYS=15

# --- Retrieval scope (single-tenant) ---
# When a query comes in with the placeholder scope ("demo"), answer against this
# GitHub account's Canon so /why spans every indexed repo. Set to the org/user
# login you installed the App on (e.g. "acme-inc").
# Ignored when LORE_API_KEYS is set (multi-tenant mode below).
LORE_DEFAULT_ACCOUNT=

# --- Multi-tenant auth (opt-in) ---
# Turn the backend into a real multi-user service. Comma-separated `key:login`
# pairs map each secret API key to the ONE GitHub account it may read. When set,
# every read endpoint (/why, /lore, /canon, /memories) REQUIRES a valid key and
# answers only that key's account — users can't see each other's Canon.
# Callers pass the key as `Authorization: Bearer <key>`, `X-Lore-Key: <key>`,
# or `?key=<key>`. Leave empty to stay single-tenant (uses LORE_DEFAULT_ACCOUNT).
#   LORE_API_KEYS=lk_alice_9f3...:alice-org, lk_bob_7c2...:bob
LORE_API_KEYS=
