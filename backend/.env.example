# Copy this file to `.env` and fill in what you have.
#
# Leave GROQ_API_KEY blank to run in MOCK mode — the backend works with zero
# keys, answering /why over a curated seed corpus. Fill it in to go LIVE:
# real mem0 memory, real Groq answers, real GitHub PR ingestion.

# --- LLM (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Embeddings (local, free, no key) ---
# Runs on your machine via fastembed. Downloads once on first live run.
# EMBEDDER_DIMS must match the model: gte-large=1024, bge-small-en-v1.5=384, bge-base=768.
EMBEDDER_MODEL=thenlper/gte-large
EMBEDDER_DIMS=1024

# --- Canon storage (vector memory) ---
# "qdrant"  = local file, offline dev (default)
# "pgvector" = hosted Postgres — the shared team brain. Requires DATABASE_URL
#              and `pip install -r requirements-pgvector.txt`.
VECTOR_STORE=qdrant
# Supabase/Neon connection string, e.g. postgresql://user:pass@host:5432/db?sslmode=require
DATABASE_URL=

# --- Optional: live GitHub PR ingestion (personal token) ---
# A classic or fine-grained token with read access to the repos you ingest.
GITHUB_TOKEN=

# --- GitHub App webhook (auto-capture merged PRs) ---
# The secret you set when creating the GitHub App; verifies webhook authenticity.
GITHUB_WEBHOOK_SECRET=
